{
  "schema_version": "aal.runes.execution_artifact.v1",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "artifact_id",
    "rune_id",
    "timestamp",
    "phase",
    "status",
    "inputs",
    "outputs",
    "provenance",
    "ledger_record_ids",
    "ledger_artifact_ids",
    "correlation_pointers"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "aal.runes.execution_artifact.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "rune_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "phase": {
      "type": "string",
      "enum": [
        "PLAN",
        "WAIT",
        "EXECUTE",
        "VALIDATE",
        "INGEST",
        "SCAN",
        "PARSE",
        "MAP",
        "DIFF",
        "ERS"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["SUCCESS", "FAILED", "NOT_COMPUTABLE"]
    },
    "inputs": {
      "$ref": "#/definitions/rune_inputs"
    },
    "outputs": {
      "$ref": "#/definitions/rune_outputs"
    },
    "provenance": {
      "type": "object",
      "required": ["source_refs"],
      "properties": {
        "source_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "operator": {"type": "string"},
        "notes": {"type": "string"},
        "unresolved_linkage": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "ledger_record_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "ledger_artifact_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "correlation_pointers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": {"type": "string"},
          "value": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["PRESENT", "MISSING", "UNRESOLVED"]
          },
          "reason": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "rune_inputs": {
      "type": "object",
      "properties": {
        "payload": {},
        "content_hash": {"type": "string"},
        "meta": {"type": "object"}
      },
      "additionalProperties": true
    },
    "rune_outputs": {
      "type": "object",
      "properties": {
        "payload": {},
        "summary": {"type": "string"},
        "metrics": {"type": "object"},
        "errors": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    }
  }
}
