{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "abraxas://schemas/GapClosureInvarianceProjection.v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "invariance_counts",
    "required_thresholds",
    "unmet_conditions",
    "readiness_state",
    "promotion_decision",
    "provenance"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "invariance_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "unchecked", "provisional", "stable"],
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "unchecked": {"type": "integer", "minimum": 0},
        "provisional": {"type": "integer", "minimum": 0},
        "stable": {"type": "integer", "minimum": 0}
      }
    },
    "required_thresholds": {"type": "object", "additionalProperties": true},
    "unmet_conditions": {"type": "array", "items": {"type": "string"}},
    "readiness_state": {"type": "string"},
    "promotion_decision": {"type": "string"},
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source", "input_hash", "projection_generated_at", "deterministic_ordering"],
      "properties": {
        "source": {"type": "string"},
        "input_hash": {"type": "string"},
        "projection_generated_at": {"type": "string"},
        "deterministic_ordering": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
