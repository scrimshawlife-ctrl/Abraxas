{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://abraxas.dev/schemas/capabilities/oracle_kernel_run_input.json",
  "title": "Oracle Kernel Run Input",
  "description": "Input schema for oracle.kernel.run capability",
  "type": "object",
  "required": ["run_id", "observations"],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_-]+$"
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["term", "context", "timestamp"],
        "properties": {
          "term": {"type": "string"},
          "context": {"type": "string"},
          "timestamp": {"type": "string", "format": "date-time"}
        },
        "additionalProperties": true
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "seed": {
      "type": "integer"
    }
  },
  "additionalProperties": false
}
