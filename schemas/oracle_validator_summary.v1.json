{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "abraxas://schemas/oracle_validator_summary.v1.json",
  "type": "object",
  "required": ["schema_id", "run_id", "lane", "status", "authority_item_count", "advisory_attachment_count", "not_computable_attachments", "artifact_refs", "hashes", "boundary_confirmation"],
  "properties": {
    "schema_id": {"const": "OracleValidatorSummary.v1"},
    "run_id": {"type": "string"},
    "lane": {"type": "string"},
    "status": {"type": "string", "enum": ["PASS", "BLOCKED"]},
    "authority_item_count": {"type": "integer"},
    "advisory_attachment_count": {"type": "integer"},
    "not_computable_attachments": {"type": "array", "items": {"type": "string"}},
    "artifact_refs": {"type": "array", "items": {"type": "string"}},
    "hashes": {
      "type": "object",
      "required": ["input_hash", "authority_hash", "full_hash"],
      "properties": {
        "input_hash": {"type": "string"},
        "authority_hash": {"type": "string"},
        "full_hash": {"type": "string"}
      }
    },
    "boundary_confirmation": {"type": "string"}
  }
}
