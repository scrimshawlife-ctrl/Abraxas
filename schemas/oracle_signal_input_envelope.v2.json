{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "abraxas://schemas/oracle_signal_input_envelope.v2.json",
  "type": "object",
  "required": ["schema_id", "signal_sources", "payload", "context", "metadata"],
  "properties": {
    "schema_id": {"const": "OracleSignalInputEnvelope.v2"},
    "signal_sources": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": ["mda", "ledger", "operator_snapshot", "validator"]}
    },
    "payload": {"type": "object"},
    "context": {
      "type": "object",
      "properties": {
        "trend_inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value"],
            "properties": {
              "value": {"type": "number"},
              "label": {"type": "string"}
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["lane", "tier", "run_id"],
      "properties": {
        "lane": {"type": "string", "enum": ["forecast-active", "shadow"]},
        "tier": {"type": "string"},
        "run_id": {"type": "string"},
        "provenance": {"type": "object"},
        "display_label": {"type": ["string", "null"]},
        "operator_note": {"type": ["string", "null"]}
      }
    }
  }
}
