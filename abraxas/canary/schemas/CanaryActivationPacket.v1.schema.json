    "entry_id": {"type": ["string", "null"]},
    "proposal_id": {"type": ["string", "null"]},
    "source_key": {"type": "string"},
    "recommendation_status": {"type": "string"},
    "packet_status": {"const": "pending_review"},
    "summary": {"type": "object"},
    "evidence": {"type": "object"},
    "lineage": {"type": "object"},
    "review": {"type": "object"},
    "authority": {"type": "object"}
  }
}
