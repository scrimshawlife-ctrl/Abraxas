{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BindingValidationReport.v1",
  "type": "object",
  "required": ["schema_version", "status", "subsystems", "missing_subsystems", "drift_flags"],
  "properties": {
    "schema_version": { "const": "BindingValidationReport.v1" },
    "status": { "enum": ["PASS", "PARTIAL", "FAIL", "NOT_COMPUTABLE"] },
    "subsystems": { "type": "array" },
    "missing_subsystems": { "type": "array", "items": { "type": "string" } },
    "drift_flags": { "type": "array", "items": { "type": "string" } }
  }
}
