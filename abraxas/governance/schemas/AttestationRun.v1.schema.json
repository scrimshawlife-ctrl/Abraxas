{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AttestationRun.v1",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "provenance",
    "files_indexed",
    "sha256_map",
    "missing_roots",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "AttestationRun.v1" },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "provenance": { "type": "object" },
    "files_indexed": { "type": "array", "items": { "type": "string" } },
    "sha256_map": { "type": "object", "additionalProperties": { "type": "string" } },
    "missing_roots": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["PASS", "PARTIAL", "FAIL"] }
  }
}
